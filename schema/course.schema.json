{
  "$anchor": "hotgrid-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_components": {
            "type": "object",
            "default": {},
            "properties": {
                "_hotgrid": {
                  "type": "object",
                  "title": "Hotgrid",
                  "default": {},
                  "properties": {
                    "ariaRegion": {
                      "type": "string",
                      "title": "Aria region",
                      "default": "Selectable image component. Select each item to show more information."
                    },
                    "item": {
                      "type": "string",
                      "title": "Item label",
                      "description": "This is the aria label that indicates the item number.",
                      "default": "Item"
                    },
                    "previous": {
                      "type": "string",
                      "title": "Popup previous label",
                      "description": "This is the aria label for the previous button in the popup.",
                      "default": "{{#if isAtStart}}{{_globals._accessibility._ariaLabels.previous}}{{else}}{{#if title}}Back to {{{title}}}{{else}}{{_globals._accessibility._ariaLabels.previous}}{{/if}} (item {{itemNumber}} of {{totalItems}}){{/if}}",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "next": {
                      "type": "string",
                      "title": "Popup next label",
                      "description": "This is the aria label for the next button in the popup.",
                      "default": "{{#if isAtEnd}}{{_globals._accessibility._ariaLabels.next}}{{else}}{{#if title}}Forward to {{{title}}}{{else}}{{_globals._accessibility._ariaLabels.next}}{{/if}} (item {{itemNumber}} of {{totalItems}}){{/if}}",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "popupPagination": {
                      "type": "string",
                      "title": "Popup pagination",
                      "description": "This is the aria label for each item. Use {{itemNumber}} and {{totalItems}} in your text to tell the user which item they are viewing and how many items there are in total.",
                      "default": "{{itemNumber}} / {{totalItems}}",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
