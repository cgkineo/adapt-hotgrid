{
  "name": "adapt-hotgrid",
  "version": "4.10.0",
  "framework": ">=5.46.4",
  "homepage": "https://github.com/cgkineo/adapt-hotgrid",
  "issues": "https://github.com/cgkineo/adapt-hotgrid/issues/",
  "component": "hotgrid",
  "targetAttribute": "_hotgrid",
  "displayName": "Hotgrid",
  "description": "A component that displays selectable images in a grid format.",
  "main": "/js/adapt-hotgrid.js",
  "keywords": [
    "adapt-plugin",
    "adapt-component"
  ],
  "license": "GPL-3.0",
  "private": true,
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "conventional-changelog-eslint": "^3.0.9",
    "semantic-release": "^25.0.2",
    "semantic-release-replace-plugin": "^1.2.7"
  },
  "scripts": {
    "postversion": "cp package.json bower.json"
  },
  "release": {
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "eslint"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "eslint"
        }
      ],
      [
        "semantic-release-replace-plugin",
        {
          "replacements": [
            {
              "files": "migrations/*.js",
              "from": "@@CURRENT_VERSION",
              "to": "${lastRelease.version}",
              "countMatches": true
            },
            {
              "files": "migrations/*.js",
              "from": "@@RELEASE_VERSION",
              "to": "${nextRelease.version}",
              "countMatches": true
            }
          ]
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "bower.json",
            "migrations/*.js"
          ],
          "message": "Chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  }
}
